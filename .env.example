# Exemple de configuration pour les variables d'environnement
# Ne jamais commiter un vrai jeton !

# jeton privé généré par Vercel pour accéder aux blobs
# il est utilisé uniquement côté serveur (API/vercel/blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_YOUR_TOKEN_HERE

# paramètres Auth0 (SPA)
# créés dans le dashboard Auth0 > Applications > Single Page Application
# les variables commençant par VITE_ seront exposées au code client
VITE_AUTH0_DOMAIN=dev-w8cvwbsw0wm03wko.us.auth0.com
VITE_AUTH0_CLIENT_ID=IftxXuscKIK41Odfw2bGp1yCuD3ByJ6o

# (optionnel) url publique du blob pour chargement direct
# VITE_BLOB_URL=https://public.blob.vercel-storage.com/...

